# =============================================================================
# AWS WAFv2 Fail2ban Configuration Example (2026年最新版)
# =============================================================================

# AWS Configuration
aws_region  = "us-east-1"
aws_profile = "YukiSunaoka"
environment = "production"

# Domain Configuration
domain_name = "download.lovelive-presents.com"

# Rate Limiting Configuration
count_threshold        = 100    # Count threshold for alerts (WAFv2 minimum: 100)
rate_limit_requests    = 500    # Block threshold (requests in 5-minute window)
block_duration_seconds = 3600   # Block duration in seconds (1 hour)
target_path            = "/website"

# IP Lists Configuration
whitelist_ips = [
  # "192.168.1.0/24",  # Example: Internal network
  # "10.0.0.1/32",     # Example: Specific trusted IP
]

blacklist_ips = [
  # "203.0.113.0/24",  # Example: Known malicious network
  # "198.51.100.1/32", # Example: Specific blocked IP
]

# CloudFront Configuration
cloudfront_distribution_id = "E1234567890ABC"

# Security Configuration
enable_managed_rules        = false
enable_advanced_rules       = true
enable_user_agent_filtering = true
enable_ai_attack_protection = true   # 2026年AI駆動攻撃対策
enable_api_abuse_protection = true   # API乱用・SSRF対策

# IP TTL Configuration
ip_ttl_hours = 24  # 24時間後に自動でoffenderリストから削除 (0=無期限)

# Notification Configuration
notification_email = "[email]"
slack_webhook_url  = "https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK"
slack_channel      = "aws_system_notify"
teams_webhook_url  = "https://outlook.office.com/webhook/YOUR/TEAMS/WEBHOOK"

# Lambda Configuration
lambda_python_runtime = "python3.13"
